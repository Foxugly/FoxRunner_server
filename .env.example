# Runtime
APP_DEBUG=true
APP_ENV=development
APP_TIMEZONE=Europe/Brussels
APP_STATE_DIR=.runtime
APP_SLOTS_FILE=config/slots.json
APP_SCENARIOS_FILE=config/scenarios.json
APP_ARTIFACTS_DIR=.runtime/artifacts
APP_LOG_FILE=
APP_LOG_MAX_BYTES=1048576
APP_LOG_BACKUP_COUNT=3
APP_LOG_JSON=false
APP_LOG_CONSOLE_ENABLED=true
API_LOG_JSON=false
API_LOG_HTTP_ENABLED=true
APP_CHECK_INTERVAL_SECONDS=10
APP_COUNTDOWN_THRESHOLD_SECONDS=300
APP_NETWORK_RETRY_SECONDS=10
APP_PLANNING_NOTIFICATION_COOLDOWN_SECONDS=900
APP_LOCK_STALE_SECONDS=43200

# Browser automation
TASK_WINDOW_SIZE=1280,900
TASK_PAGELOAD_TIMEOUT_SECONDS=60
TASK_HEADLESS=false

# Auth and database
AUTH_DATABASE_URL=sqlite+aiosqlite:///.runtime/users.db
AUTH_SECRET=change-me-before-production-32-bytes-minimum
AUTH_JWT_LIFETIME_SECONDS=3600
API_CORS_ORIGINS=http://localhost:4200
API_CREATE_TABLES_ON_STARTUP=true
API_ENABLE_LEGACY_ROUTES=true
API_MAX_BODY_BYTES=1048576
API_REQUIRE_CELERY_WORKER=false
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_MAX_REQUESTS=60

# Celery and Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Password reset
APP_PASSWORD_RESET_URL=http://localhost:4200/reset-password

# SMTP fallback, used only when GRAPH_MAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true

# Microsoft Graph
GRAPH_MAIL_ENABLED=true
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_MAIL_SENDER=
GRAPH_WEBHOOK_CLIENT_STATE=change-me-graph-client-state
GRAPH_WEBHOOK_REQUIRE_SUBSCRIPTION=false
GRAPH_SUBSCRIPTION_RENEW_ENABLED=true
GRAPH_SUBSCRIPTION_RENEW_INTERVAL_SECONDS=3600
GRAPH_SUBSCRIPTION_RENEW_BEFORE_HOURS=24
GRAPH_SUBSCRIPTION_RENEW_EXTENSION_HOURS=48

# Retention tasks
RETENTION_PRUNE_ENABLED=false
RETENTION_PRUNE_INTERVAL_SECONDS=86400
RETENTION_JOBS_DAYS=30
RETENTION_AUDIT_DAYS=180
RETENTION_GRAPH_NOTIFICATIONS_DAYS=30
RETENTION_ARTIFACTS_DAYS=30

# Smoke tests
SMOKE_BASE_URL=http://127.0.0.1:8000
SMOKE_EMAIL=
SMOKE_PASSWORD=
SMOKE_TIMEOUT_SECONDS=10
