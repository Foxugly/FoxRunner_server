  "scenarios": {
    "solidaris_pointer": {
      "description": "Pointage Solidaris via Selenium",
      "before_steps": [
        {
          "type": "require_enterprise_network",
          "ref": {
            "network": "office"
          }
        }
      ],
      "steps": [
        {
          "type": "open_url",
          "url": "https://solidaris.get.be/Primetime/webapp/?locale=fr"
        },
        {
          "type": "sleep_random",
          "min_seconds": 5,
          "max_seconds": 10
        },
        {
          "type": "click",
          "by": "id",
          "timeout": 30,
          "locator": "login"
        },
        {
          "type": "sleep_random",
          "min_seconds": 5,
          "max_seconds": 10
        },
        {
          "type": "click",
          "by": "xpath",
          "timeout": 30,
          "locator": "//button[normalize-space()='Pointer']"
        },
        {
          "type": "sleep",
          "seconds": 5
        }
      ],
      "on_success": [
        {
          "type": "notify",
          "ref": {
            "pushover": "default"
          },
          "message": "Action executee avec succes."
        }
      ],
      "on_failure": [
        {
          "type": "notify",
          "ref": {
            "pushover": "ops"
          },
          "message": "Echec de la tache a l'etape {current_step}: {error_message}"
        }
      ],
      "finally_steps": [
        {
          "type": "notify",
          "ref": {
            "pushover": "default"
          },
          "message": "Fin du scenario {scenario_id} pour le slot {slot_id}."
        }
      ]
    }
  }
}
